MWM_DATA_DIR=/opt/mihomo-web-manager/data
MWM_BACKUP_DIR=/opt/mihomo-web-manager/backups
MWM_WEB_DIR=/opt/mihomo-web-manager/web/dist
MWM_SERVICE_MODE=systemd

